# Database (Turso / libsql)
# ローカル開発（ファイルDB）
TURSO_DATABASE_URL="file:local.db"
# TURSO_AUTH_TOKEN はローカルファイルの場合不要

# 本番（Turso Cloud）
# TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-please-change-this

# Allowed emails (comma-separated, leave empty to allow all users during development)
ALLOWED_EMAILS=your-email@example.com,another-email@example.com

# GitHub OAuth
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret

# Google OAuth
GOOGLE_ID=your-google-client-id
GOOGLE_SECRET=your-google-client-secret

# Google Tag Manager (optional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX